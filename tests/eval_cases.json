[
  {
    "id": "TC001",
    "name": "location_denied",
    "description": "Verify that when location permission is denied, the agent prompts for pincode entry.",
    "state": {
      "step": "ask_permission"
    },
    "user_input": {
      "permission": false
    },
    "expected_next_step": "ask_pincode",
    "expected_input_requirement": "pincode"
  },
  {
    "id": "TC002",
    "name": "pincode_fails",
    "description": "Verify that when pincode resolution fails, the agent falls back to manual city and country entry.",
    "state": {
      "step": "ask_pincode"
    },
    "user_input": {
      "pincode": "00000"
    },
    "expected_next_step": "ask_manual",
    "expected_input_requirement": "manual_address"
  },
  {
    "id": "TC003",
    "name": "weather_api_fails",
    "description": "Verify that when the weather API is unavailable, the orchestrator prompts for manual temperature input.",
    "state": {
      "step": "weather",
      "collected_data": {
        "city": "UnknownCity",
        "country": "UnknownCountry"
      }
    },
    "user_input": {},
    "simulate_api_error": true,
    "expected_prompt_keyword": "temperature manually",
    "expected_input_requirement": "manual_weather_temp"
  },
  {
    "id": "TC004",
    "name": "rate_not_found",
    "description": "Verify that when the location is not in the database and no default tariff exists, the agent prompts for manual rate entry.",
    "state": {
      "step": "ask_user_rate",
      "city": "UnknownCity",
      "country": "Atlantis"
    },
    "user_input": {
      "manual": false
    },
    "expected_next_step": "force_manual",
    "expected_input_requirement": "manual_rate"
  },
  {
    "id": "TC005",
    "name": "unrealistic_rate",
    "description": "Verify that negative or zero rate values are rejected by the tariff validation logic.",
    "state": {
      "step": "force_manual",
      "city": "Mumbai",
      "country": "India"
    },
    "user_input": {
      "rate": -1.5,
      "fixed_charge": 0
    },
    "expected_error": "Invalid rate value",
    "expected_input_requirement": "manual_rate"
  },
